n <- 81
i = 2
while( n %% i != 0){
# print(i) para mostrar i
# Si el residuo es diferente de 0
# es porque el número no lo divide
i <- i+1
}
ifelse(i==n,
paste("El número",n,"es primo"),
paste("El número",n,"no es primo y es múltiplo de",i))
